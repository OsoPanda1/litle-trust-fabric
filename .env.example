# =============================================================================
# LITLE Trust Fabric — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Supabase (required) ---
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""        # Server-only; never expose to client

# Client-side Supabase (VITE_* prefix auto-exposed to browser)
VITE_SUPABASE_PROJECT_ID="${SUPABASE_PROJECT_ID}"
VITE_SUPABASE_PUBLISHABLE_KEY="${SUPABASE_PUBLISHABLE_KEY}"
VITE_SUPABASE_URL="${SUPABASE_URL}"

# --- OpenAI (optional — used for AI triangulation enhancement) ---
OPENAI_API_KEY=""                    # sk-... (server-side only)
OPENAI_ORG_ID=""                     # optional org ID
OPENAI_MODEL="gpt-4o"               # model for epistemic scoring, Isabella AI, speech & vision
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- LITLE (required) ---
LITLE_AUTHOR_SECRET=""               # 64+ char hex; used for PQC key derivation
LITLE_ENVIRONMENT="development"      # development | staging | production
LITLE_FEDERATION_ID="FED-1"          # Default federation for signing

# --- Deployment (optional overrides) ---
PORT="3000"                          # Dev server port
NODE_ENV="development"               # development | production
PUBLIC_URL="http://localhost:3000"   # Canonical deployment URL

# --- Observability (optional) ---
GRAFANA_URL=""                       # Grafana instance URL
OTEL_EXPORTER_OTLP_ENDPOINT=""       # OpenTelemetry endpoint
LITLE_LOG_LEVEL="info"               # debug | info | warn | error

# --- CORS (optional — for production deployments) ---
CORS_ALLOWED_ORIGINS=""              # Comma-separated list of allowed origins
